{
	"cmd": [
		"bundle",
		"exec",
		"rspec",
		"--format",
		"failures",
	],
	"keyfiles": [
		"Gemfile",
		"Gemfile.lock"
	],
	"selector": "source.ruby",
	"file_regex": "([A-Za-z0-9_.\/ ]+rb):([0-9]+):",
	"syntax": "Packages/RSpec/RSpec output.sublime-syntax",
	"working_dir": "${project_path:${folder:${file_path}}}",
}
